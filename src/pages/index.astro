---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolLogo from '../components/ToolLogo.astro';

const title = "India's Best AI Tools, Honest Reviews with INR Pricing";
const description = "AI tool reviews built for Indians. INR pricing, GST guidance, payment workflows, and use-cases for freelancers, creators, CAs, and small businesses.";

// Every AI tool we cover, equal treatment, alphabetical so no brand is "hero"
const tools = [
  { slug: 'canva',      name: 'Canva',        meta: 'Design, posters, social posts',         price: '₹590',   href: '/tools/canva-india/' },
  { slug: 'chatgpt',    name: 'ChatGPT',      meta: 'General writing, research, coding',     price: '₹2,358', href: '/tools/chatgpt-india/' },
  { slug: 'claude',     name: 'Claude',       meta: 'Long-form writing, analysis, code',      price: '₹2,005', href: '/tools/claude-india/' },
  { slug: 'copilot',    name: 'GitHub Copilot', meta: 'In-editor code autocomplete',          price: '₹845',   href: '/tools/copilot-india/' },
  { slug: 'gemini',     name: 'Gemini',       meta: 'Google integration, free tier strong',   price: '₹2,358', href: '/tools/gemini-india/' },
  { slug: 'midjourney', name: 'Midjourney',   meta: 'AI image generation for marketing',      price: '₹845',   href: '/tools/midjourney-india/' },
  { slug: 'notion',     name: 'Notion AI',    meta: 'Notes, docs, summaries inside Notion',   price: '₹979',   href: '/tools/notion-india/' },
  { slug: 'perplexity', name: 'Perplexity',   meta: 'AI search with sources, news research',  price: '₹1,690', href: '/tools/perplexity-india/' },
];
---
<BaseLayout title={title} description={description} type="website">

  <!-- HERO with animated gradient wave -->
  <section class="hero-wave relative overflow-hidden pt-16 pb-20">
    <div class="hero-wave-bg" aria-hidden="true">
      <span class="hw-rose"></span>
      <span class="hw-fuchsia"></span>
      <span class="hw-lime"></span>
      <span class="hw-rose-2"></span>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-20">
      <span class="pill mb-6"><span class="pill-ticker"></span> Updated &middot; May 2026</span>
      <h1 class="mb-6 max-w-[20ch]">
        Find the right <span class="highlight">AI tool</span> for your work, at the price you'll <span class="text-pink">actually pay</span> in <span class="handwrite">India.</span>
      </h1>
      <p class="text-xl text-ink-soft max-w-[60ch] leading-snug mb-9">
        AI tools are software that can write your emails, design posters, summarise meetings, or write code for you, for example ChatGPT, Claude, Notion, and Canva. Most charge around &#8377;2,000 per month from India after tax. We tested 7 of them honestly. Here's what actually works for Indian users.
      </p>
      <div class="flex flex-wrap gap-3 items-center">
        <a href="/for/freelancers/" class="btn btn-primary">Read the 6 starter guides <span class="arrow">&rarr;</span></a>
        <a href="/pricing-in-inr/" class="btn btn-secondary">See all prices in rupees</a>
        <span class="ml-2 text-sm text-ink-soft flex items-center gap-2">
          <span class="text-orange text-base tracking-wider">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          Honest reviews &middot; no sponsored content
        </span>
      </div>
    </div>
  </section>

  <!-- MARQUEE — all tools, with real logos -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {[...tools, ...tools].map((t) => (
        <span class="marquee-item" style="display:inline-flex;align-items:center;gap:8px;">
          <ToolLogo slug={t.slug} name={t.name} size="sm" />
          <span style="font-weight:700;">{t.name}</span> tested
        </span>
      ))}
    </div>
  </div>

  <!-- WHAT YOU CAN DO WITH THESE TOOLS -->
  <section class="max-w-6xl mx-auto px-6 py-16 reveal">
    <div class="mb-10 max-w-[720px]">
      <span class="section-eyebrow yellow">In simple words</span>
      <h2>What can these AI tools <span class="handwrite">actually do</span> for you?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      <div class="glow-card">
        <span class="glow-tag">Writing</span>
        <h3>Write emails, posts, and reports faster</h3>
        <p>Tell ChatGPT or Claude what you want to say, and it writes a first draft for you. You edit and send. Saves 30 to 60 minutes per long email or report.</p>
      </div>
      <div class="glow-card">
        <span class="glow-tag">Design</span>
        <h3>Make posters, social posts, and presentations</h3>
        <p>Canva and similar tools let you type what you want and get a finished design. No need to learn Photoshop. Useful for shop flyers, Instagram posts, or quick slide decks.</p>
      </div>
      <div class="glow-card">
        <span class="glow-tag">Office work</span>
        <h3>Summarise meetings and long PDFs</h3>
        <p>Upload a 30-page contract or a 1-hour meeting recording. Within seconds, you get the key points in a paragraph. Saves hours every week for managers and CAs.</p>
      </div>
    </div>
  </section>

  <!-- BY PROFESSION -->
  <section class="max-w-6xl mx-auto px-6 py-16 reveal">
    <div class="mb-10 max-w-[720px]">
      <span class="section-eyebrow blue">By profession</span>
      <h2>Pick the right AI tools for <span class="handwrite">your work</span>.</h2>
      <p class="text-lg text-ink-soft mt-3">Different jobs need different tools. We have a guide for each profession with the best 3 picks, INR pricing, and use cases tailored to Indian work.</p>
    </div>
    <div class="prof-grid">
      <a href="/for/teachers/" class="prof-card">
        <span class="prof-icon" aria-hidden="true">📚</span>
        <span class="prof-name">For Teachers</span>
        <span class="prof-meta">Lesson plans, grading, worksheets. Best 3 tools for school and college teachers in India.</span>
        <span class="prof-cta">Read the guide <span aria-hidden="true">&rarr;</span></span>
      </a>
      <a href="/for/engineers/" class="prof-card">
        <span class="prof-icon" aria-hidden="true">💻</span>
        <span class="prof-name">For Engineers</span>
        <span class="prof-meta">Code review, system design, tests, in-editor autocomplete. Best 3 tools for Indian software developers.</span>
        <span class="prof-cta">Read the guide <span aria-hidden="true">&rarr;</span></span>
      </a>
      <a href="/for/doctors/" class="prof-card">
        <span class="prof-icon" aria-hidden="true">🩺</span>
        <span class="prof-name">For Doctors</span>
        <span class="prof-meta">Patient communication, research summaries, handouts. Best 3 tools for Indian healthcare professionals.</span>
        <span class="prof-cta">Read the guide <span aria-hidden="true">&rarr;</span></span>
      </a>
      <a href="/for/cas/" class="prof-card">
        <span class="prof-icon" aria-hidden="true">📊</span>
        <span class="prof-name">For CAs</span>
        <span class="prof-meta">Client letters, audit summaries, GST research. Best 3 tools for Indian Chartered Accountants.</span>
        <span class="prof-cta">Read the guide <span aria-hidden="true">&rarr;</span></span>
      </a>
      <a href="/for/freelancers/" class="prof-card">
        <span class="prof-icon" aria-hidden="true">✍️</span>
        <span class="prof-name">For Freelancers</span>
        <span class="prof-meta">Client work, content, design, project management. Best 8 tools for Indian freelancers.</span>
        <span class="prof-cta">Read the guide <span aria-hidden="true">&rarr;</span></span>
      </a>
      <a href="/for/creators/" class="prof-card">
        <span class="prof-icon" aria-hidden="true">🎬</span>
        <span class="prof-name">For Creators</span>
        <span class="prof-meta">Scripts, thumbnails, captions, image generation. Best 3 tools for Indian YouTubers and creators.</span>
        <span class="prof-cta">Read the guide <span aria-hidden="true">&rarr;</span></span>
      </a>
    </div>
  </section>

  <!-- STATS -->
  <section class="max-w-6xl mx-auto px-6 py-12 reveal">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="stat-card yellow">
        <div class="stat-corner">tested</div>
        <div class="stat-num">7</div>
        <div class="stat-label">AI tools tested for Indian users</div>
      </div>
      <div class="stat-card pink">
        <div class="stat-corner">conversion</div>
        <div class="stat-num">&#8377;84<span class="small">.50</span></div>
        <div class="stat-label">= 1 US dollar (used to convert prices)</div>
      </div>
      <div class="stat-card blue">
        <div class="stat-corner">payment</div>
        <div class="stat-num">16<span class="small">%</span></div>
        <div class="stat-label">of Indian cards rejected on first payment</div>
      </div>
      <div class="stat-card mint">
        <div class="stat-corner">testing</div>
        <div class="stat-num">47<span class="small">hrs</span></div>
        <div class="stat-label">of testing behind every review</div>
      </div>
    </div>
  </section>

  <!-- MAIN CARDS — skew gradient -->
  <section class="skew-stage py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12 max-w-[720px]">
        <span class="section-eyebrow yellow">Start here</span>
        <h2 class="text-bg">The <span class="handwrite">6 guides</span> we'd send to a friend in India today.</h2>
        <p class="text-lg text-bg/75 mt-3">Each guide answers one clear question. No jargon, no fluff.</p>
      </div>
      <div class="skew-grid">

        <a href="/vs/chatgpt-vs-claude-india/" class="skew-card">
          <span class="skew-card-bg-glow skew-grad-1"></span>
          <span class="skew-card-bg skew-grad-1"></span>
          <span class="skew-orb tl"></span>
          <span class="skew-orb br"></span>
          <div class="skew-card-body">
            <span class="skew-card-tag">Comparison</span>
            <h3>ChatGPT or Claude, which one should you pick?</h3>
            <p>The two most popular AI chatbots, both priced around &#8377;2,000 a month. We tested both from India. One wins clearly for everyday work.</p>
            <span class="skew-card-cta">Read more <span aria-hidden="true">&rarr;</span></span>
          </div>
        </a>

        <a href="/for/freelancers/" class="skew-card">
          <span class="skew-card-bg-glow skew-grad-5"></span>
          <span class="skew-card-bg skew-grad-5"></span>
          <span class="skew-orb tl"></span>
          <span class="skew-orb br"></span>
          <div class="skew-card-body">
            <span class="skew-card-tag">For freelancers</span>
            <h3>The 8 best AI tools for Indian freelancers</h3>
            <p>If you work freelance, these 8 tools save hours every week and pay for themselves on your first client invoice.</p>
            <span class="skew-card-cta">Read more <span aria-hidden="true">&rarr;</span></span>
          </div>
        </a>

        <a href="/tools/chatgpt-india/" class="skew-card">
          <span class="skew-card-bg-glow skew-grad-3"></span>
          <span class="skew-card-bg skew-grad-3"></span>
          <span class="skew-orb tl"></span>
          <span class="skew-orb br"></span>
          <div class="skew-card-body">
            <span class="skew-card-tag">Tool review</span>
            <h3>ChatGPT in India, full price &amp; payment guide</h3>
            <p>ChatGPT is the most-used AI tool worldwide. Paying for it from India is harder than it should be. We list every payment method that actually works.</p>
            <span class="skew-card-cta">Read more <span aria-hidden="true">&rarr;</span></span>
          </div>
        </a>

        <a href="/tools/claude-india/" class="skew-card">
          <span class="skew-card-bg-glow skew-grad-6"></span>
          <span class="skew-card-bg skew-grad-6"></span>
          <span class="skew-orb tl"></span>
          <span class="skew-orb br"></span>
          <div class="skew-card-body">
            <span class="skew-card-tag">Tool review</span>
            <h3>Claude in India, how to use it &amp; how to pay</h3>
            <p>Claude often writes better long emails and reports than ChatGPT, and the free tier is genuinely useful for daily work.</p>
            <span class="skew-card-cta">Read more <span aria-hidden="true">&rarr;</span></span>
          </div>
        </a>

        <a href="/pricing-in-inr/" class="skew-card">
          <span class="skew-card-bg-glow skew-grad-2"></span>
          <span class="skew-card-bg skew-grad-2"></span>
          <span class="skew-orb tl"></span>
          <span class="skew-orb br"></span>
          <div class="skew-card-body">
            <span class="skew-card-tag">All prices</span>
            <h3>What each AI tool actually costs in rupees</h3>
            <p>Every popular AI tool's real monthly cost in INR, including the 18% Indian tax most websites don't mention. Updated weekly.</p>
            <span class="skew-card-cta">Read more <span aria-hidden="true">&rarr;</span></span>
          </div>
        </a>

        <a href="/guides/pay-for-ai-tools-india/" class="skew-card">
          <span class="skew-card-bg-glow skew-grad-4"></span>
          <span class="skew-card-bg skew-grad-4"></span>
          <span class="skew-orb tl"></span>
          <span class="skew-orb br"></span>
          <div class="skew-card-body">
            <span class="skew-card-tag">How-to guide</span>
            <h3>5 ways to actually pay for AI tools from India</h3>
            <p>UPI doesn't work on most international AI tools. Many Indian debit cards get rejected. Here are 5 payment methods that actually go through.</p>
            <span class="skew-card-cta">Read more <span aria-hidden="true">&rarr;</span></span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ALL TOOLS we cover — equal treatment for every tool -->
  <section class="max-w-6xl mx-auto px-6 py-20 reveal">
    <div class="mb-10 max-w-[720px]">
      <span class="section-eyebrow mint">All tools we cover</span>
      <h2>Every AI tool, <span class="handwrite">in one place</span>.</h2>
      <p class="text-lg text-ink-soft mt-3">No favourites. We test each tool from India, list the real INR price after tax, and write an honest review. Pick whichever fits your work, your wallet, and your payment method.</p>
    </div>
    <div class="tools-grid">
      {tools.map((t) => (
        <a href={t.href} class="tool-row">
          <ToolLogo slug={t.slug} name={t.name} size="md" />
          <div class="tool-row-body">
            <div class="tool-row-name">{t.name}</div>
            <div class="tool-row-meta">{t.meta}</div>
          </div>
          <span class="tool-row-price">{t.price}</span>
          <svg class="tool-row-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M5 10h10M10 5l5 5-5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>
    <p class="text-sm text-ink-soft mt-6 max-w-[60ch]">Prices include 18% Indian GST and are based on &#8377;84.50 per US dollar. Updated weekly. Tap any tool for the full review with payment workflow.</p>
  </section>

  <!-- COMPARISONS strip — multiple comparisons, not just one pair -->
  <section class="max-w-6xl mx-auto px-6 py-12 reveal">
    <div class="mb-8 max-w-[720px]">
      <span class="section-eyebrow lilac">Head-to-head</span>
      <h2>Compare any two before you <span class="handwrite">pay.</span></h2>
    </div>
    <div class="grid md:grid-cols-3 gap-4">
      <a href="/vs/chatgpt-vs-claude-india/" class="tool-row" style="flex-direction:column;align-items:flex-start;gap:0.75rem;">
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <ToolLogo slug="chatgpt" name="ChatGPT" size="sm" />
          <span style="font-weight:800;color:var(--pink);">vs</span>
          <ToolLogo slug="claude" name="Claude" size="sm" />
        </div>
        <div class="tool-row-name">ChatGPT vs Claude</div>
        <div class="tool-row-meta">Two ₹2,000/month chatbots. One handles Indian payments better.</div>
      </a>
      <a href="/vs/chatgpt-vs-gemini-india/" class="tool-row" style="flex-direction:column;align-items:flex-start;gap:0.75rem;">
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <ToolLogo slug="chatgpt" name="ChatGPT" size="sm" />
          <span style="font-weight:800;color:var(--pink);">vs</span>
          <ToolLogo slug="gemini" name="Gemini" size="sm" />
        </div>
        <div class="tool-row-name">ChatGPT vs Gemini</div>
        <div class="tool-row-meta">Gemini's free tier vs ChatGPT Plus. Workspace integration matters.</div>
      </a>
      <a href="/vs/notion-vs-claude-india/" class="tool-row" style="flex-direction:column;align-items:flex-start;gap:0.75rem;">
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <ToolLogo slug="notion" name="Notion AI" size="sm" />
          <span style="font-weight:800;color:var(--pink);">vs</span>
          <ToolLogo slug="claude" name="Claude" size="sm" />
        </div>
        <div class="tool-row-name">Notion AI vs Claude</div>
        <div class="tool-row-meta">Inside-Notion AI vs standalone Claude. Use-cases differ.</div>
      </a>
    </div>
  </section>

  <!-- PRICING -->
  <section class="max-w-6xl mx-auto px-6 py-20 reveal">
    <div class="mb-10 max-w-[720px]">
      <span class="section-eyebrow blue">Latest prices</span>
      <h2>What each AI tool <span class="text-pink">costs in rupees</span> from India.</h2>
      <p class="text-lg text-ink-soft mt-3">These are the real amounts that hit your card after the 18% Indian tax. Based on &#8377;84.50 to a US dollar. Updated weekly.</p>
    </div>
    <div class="bg-bg-2 border-2 border-ink rounded-3xl p-6 md:p-8 shadow-pop">
      <table class="w-full">
        <thead>
          <tr class="border-b-2 border-ink">
            <th class="text-left text-xs font-extrabold uppercase tracking-wider text-ink-soft pb-3 pr-4">Tool</th>
            <th class="text-left text-xs font-extrabold uppercase tracking-wider text-ink-soft pb-3 pr-4 hidden md:table-cell">Plan</th>
            <th class="text-right text-xs font-extrabold uppercase tracking-wider text-ink-soft pb-3 pr-4">Sticker price</th>
            <th class="text-right text-xs font-extrabold uppercase tracking-wider text-ink-soft pb-3 pr-4">+ 18% tax</th>
            <th class="text-right text-xs font-extrabold uppercase tracking-wider text-ink-soft pb-3">You pay</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-dashed border-ink/15 hover:bg-bg">
            <td class="py-3 pr-4 font-bold"><span style="display:inline-flex;align-items:center;gap:8px;"><ToolLogo slug="chatgpt" name="ChatGPT" size="sm" /> ChatGPT</span></td>
            <td class="py-3 pr-4 hidden md:table-cell">Plus</td>
            <td class="py-3 pr-4 text-right font-mono text-sm text-ink-soft">$20.00</td>
            <td class="py-3 pr-4 text-right font-mono text-sm text-ink-soft">+ &#8377;304</td>
            <td class="py-3 text-right"><span class="font-extrabold bg-yellow border-2 border-ink rounded-lg px-2 py-1 inline-block">&#8377;2,358</span></td>
          </tr>
          <tr class="border-b border-dashed border-ink/15 hover:bg-bg">
            <td class="py-3 pr-4 font-bold"><span style="display:inline-flex;align-items:center;gap:8px;"><ToolLogo slug="claude" name="Claude" size="sm" /> Claude</span></td>
            <td class="py-3 pr-4 hidden md:table-cell">Pro</td>
            <td class="py-3 pr-4 text-right font-mono text-sm text-ink-soft">$20.00</td>
            <td class="py-3 pr-4 text-right font-mono text-sm text-ink-soft">+ &#8377;258</td>
            <td class="py-3 text-right"><span class="font-extrabold bg-yellow border-2 border-ink rounded-lg px-2 py-1 inline-block">&#8377;2,005</span></td>
          </tr>
          <tr class="border-b border-dashed border-ink/15 hover:bg-bg">
            <td class="py-3 pr-4 font-bold"><span style="display:inline-flex;align-items:center;gap:8px;"><ToolLogo slug="notion" name="Notion AI" size="sm" /> Notion AI</span></td>
            <td class="py-3 pr-4 hidden md:table-cell">Add-on</td>
            <td class="py-3 pr-4 text-right font-mono text-sm text-ink-soft">$10.00</td>
            <td class="py-3 pr-4 text-right font-mono text-sm text-ink-soft">+ &#8377;149</td>
            <td class="py-3 text-right"><span class="font-extrabold bg-yellow border-2 border-ink rounded-lg px-2 py-1 inline-block">&#8377;979</span></td>
          </tr>
          <tr class="border-b border-dashed border-ink/15 hover:bg-bg">
            <td class="py-3 pr-4 font-bold"><span style="display:inline-flex;align-items:center;gap:8px;"><ToolLogo slug="canva" name="Canva" size="sm" /> Canva</span></td>
            <td class="py-3 pr-4 hidden md:table-cell">Pro</td>
            <td class="py-3 pr-4 text-right font-mono text-sm text-ink-soft">&#8377;500</td>
            <td class="py-3 pr-4 text-right font-mono text-sm text-ink-soft">+ &#8377;90</td>
            <td class="py-3 text-right"><span class="font-extrabold bg-yellow border-2 border-ink rounded-lg px-2 py-1 inline-block">&#8377;590</span></td>
          </tr>
          <tr class="hover:bg-bg">
            <td class="py-3 pr-4 font-bold"><span style="display:inline-flex;align-items:center;gap:8px;"><ToolLogo slug="gemini" name="Gemini" size="sm" /> Gemini</span></td>
            <td class="py-3 pr-4 hidden md:table-cell">Advanced</td>
            <td class="py-3 pr-4 text-right font-mono text-sm text-ink-soft">$20.00</td>
            <td class="py-3 pr-4 text-right font-mono text-sm text-ink-soft">+ &#8377;304</td>
            <td class="py-3 text-right"><span class="font-extrabold bg-yellow border-2 border-ink rounded-lg px-2 py-1 inline-block">&#8377;2,358</span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- BIG CTA -->
  <section class="max-w-6xl mx-auto px-6 py-12 reveal">
    <div class="bigcta-card pink">
      <h2>Get the new reviews <span class="handwrite">every Friday.</span></h2>
      <p>One short email each week with the latest review, any price changes, and news that actually matters for AI users in India. Free to subscribe, easy to unsubscribe.</p>
      <a href="#newsletter" class="btn btn-yellow">Subscribe (free) <span class="arrow">&rarr;</span></a>
    </div>
  </section>

</BaseLayout>
