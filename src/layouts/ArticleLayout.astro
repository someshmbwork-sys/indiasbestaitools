---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';

export interface Props {
  title: string;
  metaTitle: string;
  description: string;
  kicker: string;
  publishedAt?: string;
  updatedAt?: string;
  readTime?: string;
  toolName?: string;
  toolColor?: 'mint' | 'pink' | 'blue' | 'yellow' | 'lilac' | 'orange';
  // Round 15: structured-data props
  faqs?: Array<{ question: string; answer: string }>;
  reviewedItem?: { name: string; url?: string; priceInr?: string; categoryLabel?: string };
  rating?: { value: number; count?: number; best?: number };
}

const {
  title, metaTitle, description, kicker, publishedAt, updatedAt, readTime = '8 min read', toolName, toolColor = 'mint', faqs, reviewedItem, rating } = Astro.props;

// Auto-derive breadcrumbs from URL pathname (e.g. /tools/chatgpt-india/ -> Home / Tools / ChatGPT India)
const siteUrl = 'https://www.indiasbestaitools.com';
function titleCase(slug) {
  return slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
function deriveBreadcrumbs(pathname) {
  if (!pathname) return null;
  const parts = pathname.replace(/\/$/, '').split('/').filter(Boolean);
  if (parts.length === 0) return null;
  const sectionLabels = { tools: 'Reviews', vs: 'Comparisons', for: 'By profession', guides: 'Guides' };
  const items = [{ name: 'Home', url: siteUrl + '/' }];
  let acc = '';
  for (let i = 0; i < parts.length; i++) {
    acc += '/' + parts[i];
    const isLast = i === parts.length - 1;
    const name = i === 0 && sectionLabels[parts[i]] ? sectionLabels[parts[i]] : titleCase(parts[i]);
    items.push({ name, url: siteUrl + acc + (isLast ? '/' : '/') });
  }
  return items;
}
const breadcrumbs = deriveBreadcrumbs(Astro.url?.pathname);

// Build the JSON-LD graph for this article: BreadcrumbList + optional FAQPage + optional Review
const graph = [];
if (breadcrumbs && breadcrumbs.length > 1) {
  graph.push({
    '@type': 'BreadcrumbList',
    'itemListElement': breadcrumbs.map((b, i) => ({
      '@type': 'ListItem',
      'position': i + 1,
      'name': b.name,
      'item': b.url,
    })),
  });
}
if (faqs && faqs.length) {
  graph.push({
    '@type': 'FAQPage',
    'mainEntity': faqs.map(f => ({
      '@type': 'Question',
      'name': f.question,
      'acceptedAnswer': { '@type': 'Answer', 'text': f.answer },
    })),
  });
}
if (reviewedItem) {
  const review = {
    '@type': 'Review',
    'itemReviewed': {
      '@type': reviewedItem.categoryLabel === 'SaaS' ? 'SoftwareApplication' : 'Product',
      'name': reviewedItem.name,
      ...(reviewedItem.url ? { 'url': reviewedItem.url } : {}),
      ...(reviewedItem.priceInr ? {
        'offers': {
          '@type': 'Offer',
          'priceCurrency': 'INR',
          'price': reviewedItem.priceInr,
          'availability': 'https://schema.org/InStock',
        }
      } : {}),
    },
    'author': { '@type': 'Organization', 'name': "India's Best AI Tools", 'url': siteUrl },
    'datePublished': publishedAt,
    'reviewBody': description,
  };
  if (rating) {
    review.reviewRating = {
      '@type': 'Rating',
      'ratingValue': rating.value,
      'bestRating': rating.best || 5,
    };
  }
  graph.push(review);
}
const ldGraph = graph.length ? { '@context': 'https://schema.org', '@graph': graph } : null;
---
<BaseLayout
  title={metaTitle}
  description={description}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <section class="relative overflow-hidden pt-12 pb-16">
    <div class="blob blob-mint" style="width: 480px; height: 480px; top: -120px; right: -100px; filter: blur(60px);"></div>
    <div class="blob blob-pink" style="width: 360px; height: 360px; bottom: -60px; left: -80px; filter: blur(60px); opacity: 0.35;"></div>
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="text-sm text-ink-soft font-semibold mb-4">
        <a href="/" class="hover:text-pink">Index</a>
        <span class="mx-2 opacity-40">/</span>
        <a href="/" class="hover:text-pink">Reviews</a>
        <span class="mx-2 opacity-40">/</span>
        <span class="text-ink font-bold">{kicker}</span>
      </div>

      <div class="grid lg:grid-cols-[1fr_auto] gap-10 items-end">
        <div>
          <span class="pill pill-mint mb-5">&#9733; {kicker} &middot; Issue 26</span>
          <h1 class="mb-6 max-w-[18ch]" set:html={title} />
          <p class="text-xl text-ink-soft max-w-[60ch] leading-snug mb-8">{description}</p>
          <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm font-semibold text-ink-soft">
            {publishedAt && <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-pink"></span> Published <strong class="text-ink font-extrabold">{publishedAt}</strong></span>}
            {updatedAt && <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-pink"></span> Updated <strong class="text-ink font-extrabold">{updatedAt}</strong></span>}
            <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-pink"></span> <strong class="text-ink font-extrabold">{readTime}</strong></span>
            <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-pink"></span> <strong class="text-ink font-extrabold">Independent review</strong></span>
          </div>
        </div>
        {toolName && (
          <div class:list={["tool-mega", toolColor]}>{toolName}</div>
        )}
      </div>
    </div>
  </section>

  {ldGraph && (
    <script type="application/ld+json" set:html={JSON.stringify(ldGraph)} />
  )}

  <article class="max-w-3xl mx-auto px-6 pb-16">
    <div class="prose-content">
      <slot />
    </div>

    <AdSlot slot="end-of-article" />

    <div class="mt-16 pt-8 border-t-2 border-dashed border-ink/15">
      <span class="kicker">Honest disclosure</span>
      <p class="text-sm text-ink-soft leading-relaxed">
        Some links on this page are affiliate links. If you sign up via our link, we earn a small commission at no extra cost to you. We only recommend tools we'd actually use ourselves, every recommendation here is based on independent testing.
      </p>
    </div>
  </article>

  <section class="max-w-6xl mx-auto px-6 mb-16 reveal">
    <div class="bigcta-card pink">
      <h2>Get the next review <span class="handwrite">first.</span></h2>
      <p>One email a week. The newest tool review, the latest INR price changes, and the one thing Indian users need to know about AI this week.</p>
      <a href="#newsletter" class="btn btn-yellow">Subscribe (free) <span class="arrow">&rarr;</span></a>
    </div>
  </section>
</BaseLayout>
