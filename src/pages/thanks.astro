---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Thanks for subscribing, India's Best AI Tools"
  description="You're on the list. The next review lands in your inbox Friday."
  type="website"
>
  <section class="max-w-3xl mx-auto px-6 py-24 text-center reveal">
    <span class="pill pill-mint mb-6">&#10003; Subscribed</span>
    <h1 class="mb-5">You're <span class="handwrite">on the list.</span></h1>
    <p class="text-lg text-ink-soft max-w-[55ch] mx-auto mb-9">
      One short email lands in your inbox each Friday, the latest review, any INR price changes that hit Indian users this week, and the one piece of news that actually matters. No spam. Unsubscribe with one click any time.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/" class="btn btn-primary">Back to homepage <span class="arrow">&rarr;</span></a>
      <a href="/pricing-in-inr/" class="btn btn-secondary">See all INR prices</a>
    </div>
    <p class="text-sm text-ink-soft mt-10">
      Tip, add <strong>hello@indiasbestaitools.com</strong> to your contacts so the email lands in your Inbox, not Promotions.
    </p>
  </section>
</BaseLayout>
