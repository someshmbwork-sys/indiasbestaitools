const faqs = [
  { question: `Is GitHub Copilot free for Indian students?`, answer: `Yes, via GitHub Student Developer Pack. Verify with your college email or college ID. Renewable annually while you're a student.` },
  { question: `Does Copilot accept UPI in India?`, answer: `Not directly. Indian credit cards work for most users without forex hassle. Many Indian debit cards also work without enabling international transactions.` },
