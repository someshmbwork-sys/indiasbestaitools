---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  publishedAt?: string;
  updatedAt?: string;
  type?: 'article' | 'website';
  ogImage?: string;
}

const {
  title, description, canonical, publishedAt = '2026-05-08', updatedAt = '2026-05-08', type = 'article', ogImage: ogImageOverride } = Astro.props;

const siteUrl = 'https://www.indiasbestaitools.com';
const fullCanonical = canonical || siteUrl + Astro.url.pathname;

// Auto-derive per-page OG image from URL pathname if no override given.
function deriveOgFromPath(pathname) {
  if (!pathname || pathname === '/' || pathname === '/index.html') return '/og/home.png';
  const parts = pathname.replace(/\/$/, '').split('/').filter(Boolean);
  if (parts.length === 0) return '/og/home.png';
  // last segment becomes the slug, e.g. /tools/chatgpt-india/ -> chatgpt-india
  return `/og/${parts[parts.length - 1]}.png`;
}

const ogImage = siteUrl + (ogImageOverride || deriveOgFromPath(Astro.url.pathname));
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="google-site-verification" content="CP0HUFREoOryczxkTskdea_rMr-mYhFmXhbAmn1Nxb0" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />

  <meta property="og:type" content={type} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="en_IN" />
  <meta property="og:site_name" content="India's Best AI Tools" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  <meta name="theme-color" content="#FFF7ED" />

  <!-- Performance: hint the browser to start TLS handshakes early for our third parties -->
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
  <link rel="dns-prefetch" href="https://www.google-analytics.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Caveat:wght@500;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Caveat:wght@500;700&display=swap" />

  {type === 'article' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org', '@type': 'Article', 'headline': title, 'description': description, 'datePublished': publishedAt, 'dateModified': updatedAt, 'image': ogImage, 'author': {
        '@type': 'Organization', 'name': "India's Best AI Tools", 'url': siteUrl
      }, 'publisher': {
        '@type': 'Organization', 'name': "India's Best AI Tools", 'url': siteUrl, 'logo': { '@type': 'ImageObject', 'url': siteUrl + '/logo-color.png', 'width': 264, 'height': 96 }
      }, 'mainEntityOfPage': fullCanonical
    })} />
  )}

  <!-- Site-wide Organization + WebSite schema (helps Google build the knowledge panel and sitelinks search box) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'Organization',
        '@id': siteUrl + '#organization',
        'name': "India's Best AI Tools",
        'url': siteUrl,
        'logo': { '@type': 'ImageObject', 'url': siteUrl + '/logo-color.png', 'width': 264, 'height': 96 },
        'description': 'Independent INR-first review journal for AI tools, written for Indian users.',
        'email': 'hello@indiasbestaitools.com',
        'foundingDate': '2026',
        'areaServed': { '@type': 'Country', 'name': 'India' },
      },
      {
        '@type': 'WebSite',
        '@id': siteUrl + '#website',
        'url': siteUrl,
        'name': "India's Best AI Tools",
        'description': 'Honest reviews of AI tools for Indian users with INR pricing, GST guidance, and payment workflows.',
        'inLanguage': 'en-IN',
        'publisher': { '@id': siteUrl + '#organization' },
      },
    ],
  })} />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-943J60MYYC"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-943J60MYYC');
  </script>

  <!-- Google AdSense (placeholder, replace ca-pub-XXX with real publisher ID once approved).
       Until then this is a no-op; the AdSlot component also no-ops without a client ID. -->
  {false && (
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
  )}
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <script>
    // Scroll-triggered reveals
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>
</body>
</html>
